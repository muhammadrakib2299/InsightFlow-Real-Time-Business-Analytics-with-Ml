# ============================================================
# InsightFlow — environment template
#
# Copy to .env and fill in. Every variable consumed by any
# service in the stack should be listed here.
# ============================================================

# ---------- Global ----------
NODE_ENV=development
LOG_LEVEL=info
TZ=UTC

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=insightflow
POSTGRES_USER=insightflow
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://insightflow:change_me@postgres:5432/insightflow?schema=public

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---------- ClickHouse ----------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=insightflow

# ---------- Kafka / Redpanda ----------
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC_EVENTS_RAW=events.raw
KAFKA_TOPIC_EVENTS_TICK=events.tick
KAFKA_CONSUMER_GROUP=events.consumer

# ---------- API (NestJS) ----------
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=900            # 15 minutes
JWT_REFRESH_TTL=604800        # 7 days
SHARE_LINK_SECRET=change_me_share
FORECAST_SERVICE_URL=http://forecast:8000
INGESTION_INTERNAL_URL=http://ingestion:5000

# ---------- Ingestion (FastAPI) ----------
INGESTION_PORT=5000
INGESTION_RATE_LIMIT_RPS=1000
INGESTION_RATE_LIMIT_BURST=5000
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# ---------- Forecast (FastAPI) ----------
FORECAST_PORT=8000
FORECAST_ARTIFACTS_DIR=/app/artifacts
FORECAST_TRAIN_WINDOW_DAYS=540   # 18 months
FORECAST_CACHE_TTL_SECONDS=86400
RETRAIN_SHARED_SECRET=change_me_retrain

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=InsightFlow

# ---------- Email (Resend) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@insightflow.local

# ---------- Object storage (MinIO, for PDF exports) ----------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PDF=insightflow-pdf

# ---------- Reverse proxy ----------
CADDY_DOMAIN=localhost
CADDY_EMAIL=admin@example.com
