# InsightFlow — Caddy reverse proxy
#
# Production-ready single-host configuration. The CADDY_DOMAIN env var picks
# whether we get automatic TLS from Let's Encrypt or stay on the internal
# self-signed cert (when set to "localhost").

{
	email {$CADDY_EMAIL}

	# Rate limit ordering — first match wins.
	order rate_limit before reverse_proxy
}

# ---------- Public dashboard + API ----------
{$CADDY_DOMAIN} {
	encode zstd gzip

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' wss: https:;"
		-Server
	}

	# Per-IP rate limit at the edge.
	# Caddy 2.8 ships a basic rate_limit module; if your build doesn't
	# include it, this directive is a no-op (we also enforce in-app via
	# @nestjs/throttler on the API layer).
	rate_limit {
		zone dashboard {
			key {remote_host}
			events 100
			window 1s
		}
	}

	# WebSocket bridge (Socket.IO)
	@ws {
		path /socket.io/*
	}
	reverse_proxy @ws api:4000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
	}

	# Dashboard API
	handle /api/* {
		reverse_proxy api:4000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}

	# Next.js frontend (catch-all)
	handle {
		reverse_proxy frontend:3000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}
}

# ---------- Public ingest endpoint ----------
# Separate hostname so the dashboard CORS policy can stay locked down
# while the ingest CORS stays open (API key is the auth boundary).
ingest.{$CADDY_DOMAIN} {
	encode gzip

	header {
		X-Content-Type-Options "nosniff"
		-Server
		# Open CORS — API key is the auth boundary, not Origin.
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "POST, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, X-Api-Key, Authorization"
	}

	@options method OPTIONS
	respond @options 204

	# Ingest rate limit — keyed by API key first, falling back to IP.
	rate_limit {
		zone ingest_per_key {
			key {http.request.header.X-Api-Key}
			events 1000
			window 1s
		}
		zone ingest_per_ip {
			key {remote_host}
			events 200
			window 1s
		}
	}

	reverse_proxy ingestion:5000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
	}
}
