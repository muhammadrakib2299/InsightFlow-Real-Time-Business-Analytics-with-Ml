# InsightFlow — Caddy reverse proxy
#
# Production-ready single-host configuration. The CADDY_DOMAIN env var picks
# whether we get automatic TLS from Let's Encrypt or stay on the internal
# self-signed cert (when set to "localhost").
#
# NOTE: the `rate_limit` directive used in the prod build of this Caddyfile
# is a third-party module (mholt/caddy-ratelimit) and is NOT included in
# the official caddy:2.8-alpine image. For local dev we run without it
# and rely on the in-app NestJS Throttler. For prod, build a custom Caddy
# image with `xcaddy build --with github.com/mholt/caddy-ratelimit` and
# re-enable the rate_limit blocks below.

{
	email {$CADDY_EMAIL}
}

# ---------- Public dashboard + API ----------
{$CADDY_DOMAIN} {
	encode zstd gzip

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' wss: https:;"
		-Server
	}

	# Per-IP rate limit — requires the rate_limit module (see note above).
	# Uncomment after building Caddy with --with github.com/mholt/caddy-ratelimit
	# rate_limit {
	# 	zone dashboard {
	# 		key {remote_host}
	# 		events 100
	# 		window 1s
	# 	}
	# }

	# WebSocket bridge (Socket.IO)
	@ws {
		path /socket.io/*
	}
	reverse_proxy @ws api:4000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
	}

	# Dashboard API
	handle /api/* {
		reverse_proxy api:4000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}

	# Next.js frontend (catch-all)
	handle {
		reverse_proxy frontend:3000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}
}

# ---------- Public ingest endpoint ----------
# Separate hostname so the dashboard CORS policy can stay locked down
# while the ingest CORS stays open (API key is the auth boundary).
ingest.{$CADDY_DOMAIN} {
	encode gzip

	header {
		X-Content-Type-Options "nosniff"
		-Server
		# Open CORS — API key is the auth boundary, not Origin.
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "POST, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, X-Api-Key, Authorization"
	}

	@options method OPTIONS
	respond @options 204

	# Per-key ingest rate limit — same module dependency as above.
	# rate_limit {
	# 	zone ingest_per_key {
	# 		key {http.request.header.X-Api-Key}
	# 		events 1000
	# 		window 1s
	# 	}
	# 	zone ingest_per_ip {
	# 		key {remote_host}
	# 		events 200
	# 		window 1s
	# 	}
	# }

	reverse_proxy ingestion:5000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
	}
}
